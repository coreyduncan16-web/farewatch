# Copy this file to .env and paste your real keys. Never commit .env.

# --- Amadeus for Developers (default provider) ---
# Get these at https://developers.amadeus.com  ->  My Self-Service Workspace  ->  Create New App
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- SerpAPI Google Flights (fallback provider, optional) ---
# Get this at https://serpapi.com  ->  Dashboard  ->  Your Private API Key
SERPAPI_KEY=

# --- Netlify hosting (optional backup/replacement for GitHub Pages) ---
# Create a free account at https://app.netlify.com, then:
# User settings -> Applications -> Personal access tokens -> New access token
NETLIFY_TOKEN=
NETLIFY_SITE_ID=

# --- Email/text alerts (optional, used by alerts.ps1) ---
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASS=an App Password you create yourself at myaccount.google.com/apppasswords
# (never your real password). SMTP_FROM is usually the same address as SMTP_USER.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
